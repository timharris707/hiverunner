# HiveRunner Voice - optional Pipecat backend
# Copy to .env and fill in your own provider keys.

# Tavus avatar video
TAVUS_API_KEY=
TAVUS_REPLICA_ID=

# Gemini LLM
GOOGLE_API_KEY=

# Deepgram speech-to-text
DEEPGRAM_API_KEY=

# Cartesia text-to-speech
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Daily.co WebRTC transport
DAILY_API_KEY=

# Local backend config
HOST=0.0.0.0
PORT=8108
HIVERUNNER_VOICE_BOT_NAME=HiveRunner Voice
HIVERUNNER_VOICE_CORS_ORIGINS=http://localhost:3010,http://localhost:3001
