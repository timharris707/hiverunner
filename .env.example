# ─── Auth mode ───────────────────────────────────────────────────────────────
# HiveRunner runs in one of two auth modes (see docs/AUTH.md for details):
#
#   - local-single-user (default for local-first GitHub installs):
#       The app trusts a single owner identity. No external auth provider
#       required. Protected orchestration routes can still be gated by
#       MC_API_KEY and the loopback policy. Suitable for a single user on
#       their own machine.
#
#   - supabase (only when MC_AUTH_MODE=supabase):
#       Hosted multi-user mode. Sessions, OAuth callbacks, and admin user
#       provisioning go through Supabase.
#
# Leave MC_AUTH_MODE unset for local-single-user, even if optional Supabase
# env vars are present. Set MC_AUTH_MODE=supabase explicitly for hosted auth.
# MC_AUTH_MODE=local-single-user

# Local-single-user owner identity (only used in local-single-user mode):
# MC_LOCAL_OWNER_EMAIL=owner@localhost.local

# ─── Supabase (required only when MC_AUTH_MODE=supabase) ─────────────────────
# Get these from your Supabase project settings.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Optional: only for audited admin provisioning paths such as loopback
# local-dev bootstrap in hosted mode.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Orchestration / agent traffic ───────────────────────────────────────────
# Shared secret required on /api/orchestration/* as X-MC-API-Key. Strongly
# recommended in any install that runs autonomous agents.
# MC_API_KEY=generate-a-long-random-secret

# Orchestration execution provider fallback (defaults to manual).
# Agent adapter_type is the source of truth for normal task routing.
# ORCHESTRATION_EXECUTION_PROVIDER=manual

# Autonomous engine loop. Port 3010 is always forced observer-only by the
# script/runtime guards. Use MC_ENGINE_TICK=on only for the stable lane or a
# separate execution lane with its own port, data dir, workspace root, and logs.
# MC_ENGINE_TICK=off

# HiveRunner-owned company/workspace storage.
# Use an absolute path when overriding the built-in local default.
# MC_WORKSPACE_ROOT=/absolute/path/to/hive-runner/workspace

# Optional isolated SQLite/data directory for local testing.
# Defaults to ./data when unset.
# MC_DATA_DIR=./data-dev

# Optional root redirect preference. The value must match an existing
# workspace/company code. If unset, HiveRunner prefers HIVE when present,
# then INS for existing local installs, then the first valid DB-backed code.
# MC_DEFAULT_COMPANY_CODE=HIVE

# ─── Legacy runtime integration (optional) ───────────────────────────────────
# Only set these when you intentionally connect an existing external runtime.
# OPENCLAW_DIR=/absolute/path/to/runtime/home
# OPENCLAW_WORKSPACE_ROOT=/absolute/path/to/runtime/workspace

# ─── Branding (customize for your instance) ─────────────────────────────────
NEXT_PUBLIC_AGENT_NAME=HiveRunner
NEXT_PUBLIC_AGENT_EMOJI=H
NEXT_PUBLIC_AGENT_DESCRIPTION=Local-first AI agent control plane
NEXT_PUBLIC_AGENT_LOCATION=
NEXT_PUBLIC_BIRTH_DATE=
NEXT_PUBLIC_AGENT_AVATAR=
NEXT_PUBLIC_OWNER_USERNAME=your-username
NEXT_PUBLIC_OWNER_EMAIL=your-email@example.com
NEXT_PUBLIC_OWNER_COLLAB_EMAIL=collabs@example.com
NEXT_PUBLIC_TWITTER_HANDLE=@username
NEXT_PUBLIC_COMPANY_NAME=HIVE RUNNER
NEXT_PUBLIC_APP_TITLE=HiveRunner

# ─── Voice (optional) ────────────────────────────────────────────────────────
# Google AI (Gemini Live voice)
# Get a key at https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=your-google-ai-api-key

# OpenAI-backed optional avatar/image generation and model-source routes.
# OPENAI_API_KEY=your-openai-api-key

# Anthropic direct model-source routes. Claude Code CLI auth is separate.
# ANTHROPIC_API_KEY=your-anthropic-api-key

# HIVERUNNER_VOICE_PROVIDER=gemini-live
# Optional local Pipecat/Tavus avatar backend.
# Start pipecat-server separately and point HiveRunner at it if needed.
# PIPECAT_URL=http://127.0.0.1:8108
# OPENAI_REALTIME_VOICE_MODEL=gpt-realtime-2
# OPENAI_REALTIME_VOICE=marin
# OPENAI_REALTIME_REASONING_EFFORT=low
# Faster turn-taking defaults for conversational voice.
# OPENAI_REALTIME_TURN_DETECTION=server_vad
# OPENAI_REALTIME_VAD_SILENCE_DURATION_MS=450
# OPENAI_REALTIME_VAD_PREFIX_PADDING_MS=250
# OPENAI_REALTIME_VAD_THRESHOLD=0.5
